{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo build",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "--bin=packrat"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "silent", "clear": true }
    },
    {
      "label": "cargo build (release)",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "--bin=packrat", "--release"],
      "group": "build",
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "silent", "clear": true }
    },
    {
      "label": "cargo build (real-capture)",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "--bin=packrat", "--features=real-capture"],
      "group": "build",
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "silent", "clear": true }
    },
    {
      "label": "cargo run",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "--bin=packrat"],
      "group": "build",
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "cargo check",
      "type": "shell",
      "command": "cargo",
      "args": ["check", "--bin=packrat"],
      "group": "build",
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "silent", "clear": true }
    },
    {
      "label": "cargo clippy",
      "type": "shell",
      "command": "cargo",
      "args": ["clippy", "--bin=packrat", "--", "-D", "warnings"],
      "group": "build",
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "always", "clear": true }
    }
  ]
}
