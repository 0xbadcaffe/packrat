{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo build",
      "type": "cargo",
      "command": "build",
      "args": ["--bin=packrat"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "silent", "clear": true }
    },
    {
      "label": "cargo build (release)",
      "type": "cargo",
      "command": "build",
      "args": ["--bin=packrat", "--release"],
      "group": "build",
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "silent", "clear": true }
    },
    {
      "label": "cargo build (real-capture)",
      "type": "cargo",
      "command": "build",
      "args": ["--bin=packrat", "--features=real-capture"],
      "group": "build",
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "silent", "clear": true }
    },
    {
      "label": "cargo run",
      "type": "cargo",
      "command": "run",
      "args": ["--bin=packrat"],
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "cargo check",
      "type": "cargo",
      "command": "check",
      "args": ["--bin=packrat"],
      "group": "build",
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "silent", "clear": true }
    },
    {
      "label": "cargo clippy",
      "type": "cargo",
      "command": "clippy",
      "args": ["--bin=packrat", "--", "-D", "warnings"],
      "group": "build",
      "problemMatcher": ["$rustc"],
      "presentation": { "reveal": "always", "clear": true }
    }
  ]
}
